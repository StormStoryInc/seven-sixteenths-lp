---
import type { Translations } from '../i18n';

interface Props { t: Translations; }
const { t } = Astro.props;
---

<section class="how-it-works" id="how-it-works">
  <div class="section-fade-top" style="background: linear-gradient(180deg, var(--black), transparent);" aria-hidden="true"></div>

  <div class="container">
    <div class="section-header reveal">
      <h2>{t.howItWorksTitle}</h2>
    </div>

    <div class="steps stagger-children">
      <div class="step reveal" style="--i: 0;">
        <div class="step-line" aria-hidden="true">
          <div class="step-dot"></div>
          <div class="step-connector"></div>
        </div>
        <div class="step-body">
          <span class="step-number">01</span>
          <h3 class="step-title">{t.step1Title}</h3>
          <p class="step-desc">{t.step1Desc}</p>
        </div>
      </div>

      <div class="step reveal" style="--i: 1;">
        <div class="step-line" aria-hidden="true">
          <div class="step-dot"></div>
          <div class="step-connector"></div>
        </div>
        <div class="step-body">
          <span class="step-number">02</span>
          <h3 class="step-title">{t.step2Title}</h3>
          <p class="step-desc">{t.step2Desc}</p>
        </div>
      </div>

      <div class="step reveal" style="--i: 2;">
        <div class="step-line" aria-hidden="true">
          <div class="step-dot"></div>
        </div>
        <div class="step-body">
          <span class="step-number">03</span>
          <h3 class="step-title">{t.step3Title}</h3>
          <p class="step-desc">{t.step3Desc}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: var(--black);
    position: relative;
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    margin-bottom: clamp(3.5rem, 7vw, 5rem);
  }

  .steps {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step {
    display: flex;
    gap: 2rem;
    position: relative;
  }

  .step-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
    padding-top: 0.35rem;
  }

  .step-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--white);
    box-shadow: 0 0 12px rgba(255, 255, 255, 0.25);
    flex-shrink: 0;
  }

  .step-connector {
    width: 1px;
    flex: 1;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.03));
    min-height: 100%;
  }

  .step-body {
    padding-bottom: 3.5rem;
  }

  .step:last-child .step-body {
    padding-bottom: 0;
  }

  .step-number {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--gray-400);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .step-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .step-desc {
    font-size: 0.9rem;
    line-height: 1.8;
    color: var(--gray-500);
  }
</style>
