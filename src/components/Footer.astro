---
import { CONTACT_EMAIL } from '../consts';
import type { Translations, Locale } from '../i18n';
import { prefix } from '../i18n';

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;
const p = prefix(locale);
const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">7/16</span>
      <p class="footer-tagline">{t.footerTagline}</p>
    </div>

    <div class="footer-links">
      <a href={`${p}/terms`}>{t.footerTerms}</a>
      <a href={`${p}/privacy`}>{t.footerPrivacy}</a>
      <a href={`${p}/child-safety`}>{t.footerChildSafety}</a>
      <a href={`mailto:${CONTACT_EMAIL}`}>{t.footerContact}</a>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} 7/16. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--gray-950);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 4rem 0 2rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }

  .footer-logo {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -1px;
    color: var(--white);
  }

  .footer-tagline {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--gray-500);
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: var(--gray-400);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--white);
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--gray-600);
  }
</style>
