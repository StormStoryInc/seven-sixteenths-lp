---
import BaseHead from '../components/BaseHead.astro';
import { t } from '../i18n';

const en = t('en');
const ja = t('ja');

const APP_STORE_URL = 'https://apps.apple.com/app/id6759083490';
const PLAY_STORE_URL = 'https://play.google.com/store/apps/details?id=net.stormstory.sevensixteenths';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={en.downloadTitle} description={en.downloadDescription} image="/og-download.png" />
		<!--
			1. Mobile → instant store redirect (JS, client-side UA detection)
			2. Desktop → show download page, language auto-detected via navigator.language
			   Both en/ja text is in the DOM; JS shows the right one instantly (no flash).
		-->
		<script is:inline define:vars={{ APP_STORE_URL, PLAY_STORE_URL }}>
			(function () {
				var ua = navigator.userAgent || navigator.vendor || '';
				// Mobile → redirect to store
				if (/iPhone|iPad|iPod/i.test(ua)) {
					window.location.replace(APP_STORE_URL);
					return;
				}
				if (/Android/i.test(ua)) {
					window.location.replace(PLAY_STORE_URL);
					return;
				}
				// Desktop → detect language and show correct text
				var isJa = /^ja\b/i.test(navigator.language || '');
				document.documentElement.lang = isJa ? 'ja' : 'en';
				document.addEventListener('DOMContentLoaded', function () {
					var show = isJa ? 'ja' : 'en';
					var hide = isJa ? 'en' : 'ja';
					document.querySelectorAll('[data-lang="' + show + '"]').forEach(function (el) {
						el.style.display = '';
					});
					document.querySelectorAll('[data-lang="' + hide + '"]').forEach(function (el) {
						el.style.display = 'none';
					});
				});
			})();
		</script>
	</head>
	<body>
		<main class="download-page">
			<div class="download-card">
				<img src="/app-icon.png" alt="7/16" class="download-icon" width="80" height="80" />
				<h1 class="download-title">7/16</h1>

				<p class="download-tagline" data-lang="en">{en.downloadTagline}</p>
				<p class="download-tagline" data-lang="ja" style="display:none">{ja.downloadTagline}</p>

				<p class="download-desc" data-lang="en">{en.downloadDesc}<br />{en.downloadDesc2}</p>
				<p class="download-desc" data-lang="ja" style="display:none">{ja.downloadDesc}<br />{ja.downloadDesc2}</p>

				<div class="download-badges">
					<a href={APP_STORE_URL} class="store-badge-link" target="_blank" rel="noopener noreferrer">
						<img src="/badges/app-store.svg" alt="Download on the App Store" height="48" />
					</a>
					<a href={PLAY_STORE_URL} class="store-badge-link" target="_blank" rel="noopener noreferrer">
						<img src="/badges/google-play.svg" alt="Get it on Google Play" height="48" />
					</a>
				</div>
			</div>
		</main>

		<style>
			.download-page {
				min-height: 100dvh;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 2rem;
				background: var(--black);
			}
			.download-card {
				text-align: center;
				max-width: 380px;
				animation: fadeUp 0.6s var(--ease-out-expo) both;
			}
			.download-icon {
				width: 80px;
				height: 80px;
				border-radius: 20px;
				margin: 0 auto 1.5rem;
			}
			.download-title {
				font-size: 2rem;
				font-weight: 900;
				letter-spacing: -0.03em;
				margin-bottom: 0.5rem;
				color: var(--white);
			}
			.download-tagline {
				font-size: 1rem;
				color: var(--gray-400);
				margin-bottom: 1.5rem;
			}
			.download-desc {
				font-size: 0.9rem;
				color: var(--gray-500);
				line-height: 1.8;
				margin-bottom: 2.5rem;
			}
			.download-badges {
				display: flex;
				gap: 0.75rem;
				justify-content: center;
				flex-wrap: wrap;
			}
			.store-badge-link {
				display: block;
				transition: opacity 0.3s, transform 0.3s;
			}
			.store-badge-link:hover {
				opacity: 0.85;
				transform: scale(1.03);
			}
			.store-badge-link img {
				height: 48px;
				width: auto;
				display: block;
			}
			@keyframes fadeUp {
				from { opacity: 0; transform: translateY(16px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@media (max-width: 480px) {
				.download-desc br { display: none; }
			}
		</style>
	</body>
</html>
